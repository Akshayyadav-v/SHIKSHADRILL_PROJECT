{
"hosting": {
 "public": "frontend",
 "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
 "rewrites": [
   {
     "source": "/api/**",
     "run": {
          "serviceId": "<REPLACE_WITH_CLOUD_RUN_SERVICE_ID>",
          "region": "<REPLACE_WITH_REGION>"
    }
 },
 {
   "source": "!/api/**",
   "destination": "/index.html"
 }
]
}
}